# JamBase v3 API key — the ONLY secret the app reads (src/lib/api/jambase.ts).
# Sent server-side as an Authorization: Bearer header, never in a URL.
JAMBASE_KEY=

# Public canonical origin used for metadata/sitemap/robots. Optional in dev
# (falls back to the production origin); set explicitly when deploying.
NEXT_PUBLIC_SITE_URL=https://earshotlive.com
